alias gst = git status

alias exa = eza --icons --color=always
alias tree = eza --tree
alias l = ls -l
alias la = ls -la
alias ll = ls -l
alias lS = ls -s
alias lt = tree --level=2

alias t = tail -f
alias tailf = tail -f

alias tf = terraform
alias kctx = kubectl config use-context
alias kns = kubectl config set-context --current --namespace

alias 'reshell!' = exec nu -l
